# Local Docker MongoDB only. Replace the placeholder password and URL-encode it in both values.
MONGO_INITDB_ROOT_USERNAME=botanica_local
MONGO_INITDB_ROOT_PASSWORD=replace-with-a-local-secret
MONGODB_URI=mongodb://botanica_local:replace-with-a-local-secret@127.0.0.1:27017/botanica-ob?authSource=admin
INTERNAL_ACCOUNT_CHECK_ORIGIN=http://127.0.0.1:3000
